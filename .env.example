# Copy this file to ".env" and add your key to make GIDEON think with Claude.
# Without a key, GIDEON still runs in a built-in "offline" personality so the
# whole experience (voice, captions, the hologram) works end to end.

ANTHROPIC_API_KEY=

# Optional overrides
PORT=8787
GIDEON_MODEL=claude-opus-4-8
