# Copy this file to ".env" and add your key to make GIDEON think with Claude.
# Without a key, GIDEON still runs in a built-in "offline" personality so the
# whole experience (voice, captions, the hologram) works end to end.

ANTHROPIC_API_KEY=

# Optional overrides
PORT=8787
GIDEON_MODEL=claude-opus-4-8

# --- Alternative brain: OpenRouter (any OpenAI-compatible model) -------------
# Set GIDEON_PROVIDER=openrouter to think with an OpenRouter model instead of
# Claude. Requires OPENROUTER_API_KEY.
# GIDEON_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
#
# Recommended for the voice: a fast, non-reasoning chat model speaks instantly.
# OPENROUTER_MODEL=google/gemma-4-31b-it:free
#
# Also fine: cohere/north-mini-code:free — but it's a *reasoning* model that
# thinks before it speaks, so the first spoken word lands a beat later.
# Heads-up: free models are sometimes rate-limited upstream (HTTP 429); GIDEON
# handles that by speaking a short "ask me again" line instead of going silent.
