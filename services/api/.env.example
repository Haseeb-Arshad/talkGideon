# Gideon API configuration. Copy to .env for local dev (loaded automatically).

# HTTP port
PORT=8787

# Postgres. Leave EMPTY to use the in-memory store (no persistence) for quick dev.
# DATABASE_URL=postgres://gideon:gideon@localhost:5432/gideon?sslmode=disable
DATABASE_URL=

# Redis (optional; reserved for hot session/cache — not required for MVP)
REDIS_URL=

# Exa web search. Leave EMPTY to use the deterministic mock searcher.
EXA_API_KEY=

# Model provider. "mock" needs no key and produces structured answers offline.
# Set to a real provider (e.g. "anthropic", "openai") + MODEL_API_KEY to swap in.
MODEL_PROVIDER=mock
MODEL_API_KEY=

# Obsidian vault root. Memories are written under <vault>/Gideon/Memories/.
OBSIDIAN_VAULT_PATH=./vault

# CORS — comma-separated origins allowed to call the API (the TanStack frontend).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# development | production  (controls log format + level)
ENVIRONMENT=development
